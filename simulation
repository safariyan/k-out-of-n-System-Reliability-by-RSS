def save_figure(fig, filename):
    fig.savefig(filename, dpi=300, bbox_inches='tight')
    print(f"  ✅ Saved: {filename}")


def Figure1_MSE_vs_delta(df):
    """Figure 1: MSE vs delta - ALL estimators"""
    fig, axes = plt.subplots(1, 3, figsize=(18, 6))
    estimators = ['MLE', 'Stein', 'PS', 'PTE', 'CW', 'Thompson', 'MS']
    colors = ['#e74c3c', '#2ecc71', '#3498db', '#f39c12', '#9b59b6', '#1abc9c', '#e67e22']
    markers = ['o', 's', '^', 'D', 'v', 'p', '*']
    
    for idx, R_true in enumerate(sorted(df['R_true'].unique())):
        ax = axes[idx]
        df_subset = df[df['R_true'] == R_true]
        
        for i, est in enumerate(estimators):
            data = df_subset[df_subset['Estimator'] == est].sort_values('delta')
            if len(data) > 0:
                ax.plot(data['delta'], data['MSE'], marker=markers[i], 
                       linewidth=2, markersize=4, label=est, color=colors[i])
        
        # MLE should be CONSTANT - draw flat line
        mle_data = df_subset[df_subset['Estimator'] == 'MLE']
        if len(mle_data) > 0:
            mle_mean = mle_data['MSE'].mean()
            ax.axhline(y=mle_mean, color='#e74c3c', 
                      linestyle='--', linewidth=2, alpha=0.5, label=f'MLE = {mle_mean:.5f}')
        
        ax.axvline(x=0, color='black', linestyle='--', linewidth=1, alpha=0.5)
        ax.set_xlabel(r'$\delta = R_0 - R_{true}$', fontsize=12)
        ax.set_ylabel('MSE', fontsize=12)
        ax.set_title(f'$R_{{true}} = {R_true:.1f}$', fontsize=13)
        ax.legend(loc='upper left', fontsize=8, ncol=2)
        ax.grid(True, alpha=0.3)
        ax.set_xlim(-0.37, 0.37)
    
    plt.suptitle('Figure 1: MSE vs $\delta$ (MLE is constant)', fontsize=15, fontweight='bold')
    plt.tight_layout()
