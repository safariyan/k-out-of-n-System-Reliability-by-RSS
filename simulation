def Figure7_Bar_Best_Worst(df):
    """Figure 7: Bar plot - Best vs Worst MSE"""
    fig, axes = plt.subplots(1, 3, figsize=(18, 6))
    estimators = ['MLE', 'Stein', 'PS', 'PTE', 'CW', 'Thompson', 'MS']
    colors = ['#e74c3c', '#2ecc71', '#3498db', '#f39c12', '#9b59b6', '#1abc9c', '#e67e22']
    
    for idx, R_true in enumerate(sorted(df['R_true'].unique())):
        ax = axes[idx]
        df_subset = df[df['R_true'] == R_true]
        
        best_data = df_subset[np.abs(df_subset['delta']) < 0.005]
        worst_data = df_subset[df_subset['delta_abs'] == df_subset['delta_abs'].max()]
        
        x = np.arange(len(estimators))
        width = 0.35
        
        best_mse = []
        worst_mse = []
        
        for est in estimators:
            best_val = best_data[best_data['Estimator'] == est]['MSE'].values
            worst_val = worst_data[worst_data['Estimator'] == est]['MSE'].values
            best_mse.append(best_val[0] if len(best_val) > 0 else 0)
            worst_mse.append(worst_val[0] if len(worst_val) > 0 else 0)
        
        bars1 = ax.bar(x - width/2, best_mse, width, label='Best (δ ≈ 0)', 
                       color='#2ecc71', edgecolor='darkgreen', linewidth=1.5)
        bars2 = ax.bar(x + width/2, worst_mse, width, label='Worst (δ = max)', 
                       color='#e74c3c', edgecolor='darkred', linewidth=1.5)
        
        for bar in bars1:
            height = bar.get_height()
            ax.annotate(f'{height:.3f}', xy=(bar.get_x() + bar.get_width()/2, height),
                       xytext=(0, 3), textcoords="offset points", ha='center', va='bottom', fontsize=7)
        for bar in bars2:
            height = bar.get_height()
            ax.annotate(f'{height:.3f}', xy=(bar.get_x() + bar.get_width()/2, height),
                       xytext=(0, 3), textcoords="offset points", ha='center', va='bottom', fontsize=7)
        
        ax.set_xlabel('Estimator', fontsize=11)
        ax.set_ylabel('MSE', fontsize=11)
        ax.set_title(f'$R_{{true}} = {R_true:.1f}$', fontsize=13)
        ax.set_xticks(x)
        ax.set_xticklabels(estimators, rotation=45, ha='right', fontsize=8)
        ax.legend(loc='upper left', fontsize=8)
