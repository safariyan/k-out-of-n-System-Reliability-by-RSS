def main():
    print("=" * 70)
    print("STARTING FINAL COMPREHENSIVE ANALYSIS")
    print("FIXED DATA for all R0 values (MLE is constant)")
    print("CORRECTED Sample Size Analysis (new data for each n)")
    print("=" * 70)

    # Verify the corrected closed-form R_{k:n} formula (eq. Rkn_exp in the
    # revised paper) against the general Beta-function form before running
    # any simulation, so a regression here fails loudly and immediately.
    max_diff = _self_check_R_k_n()
    print(f"Closed-form vs Beta-form self-check passed (max diff = {max_diff:.2e})")
    print("=" * 70)
    
    # Part 1: Sensitivity Analysis
    print("\n" + "=" * 70)
    print("PART 1: Sensitivity Analysis")
    print("=" * 70)
    
    sensitivity_df = run_sensitivity_analysis_fixed(
        n=30, m=3, k=2, n_sys=5,
        num_iter=500,
        alpha=0.7,
        R_true_values=[0.3, 0.5, 0.7],
        delta_min=-0.35,
        delta_max=0.35,
        delta_step=0.025,
        # Raised from 50 -> 200 per the paper's revised note that B=50 is
        # below the B>=1000 typically recommended for percentile bootstrap
        # CIs (Efron & Tibshirani, 1993). 200 is a practical compromise given
        # this is a NESTED bootstrap (run inside 500 x 29 x 3 outer Monte
        # Carlo iterations); set N_BOOT_FULL below and use it here if you can
        # afford the ~5x longer runtime for a final, publication-grade run.
        n_boot=200
    )
    sensitivity_df.to_csv('sensitivity_analysis_final.csv', index=False)
    
    # Part 2: CORRECTED Sample Size Analysis
    print("\n" + "=" * 70)
    print("PART 2: CORRECTED Sample Size Analysis")
    print("(NEW DATA for each n)")
    print("=" * 70)
    
    sample_size_df = run_sample_size_analysis_corrected(
        n_values=[10, 20, 30, 50, 80, 100],
        m=3, k=2, n_sys=5,
        num_iter=500,
        alpha=0.7,
