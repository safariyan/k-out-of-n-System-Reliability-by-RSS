def generate_tables(df):
    """Generate tables without RE estimator"""
    
    print("\n" + "=" * 70)
    print("TABLE 1: Best Case (δ ≈ 0)")
    print("=" * 70)
    
    best_data = df[np.abs(df['delta']) < 0.005]
    if len(best_data) > 0:
        table1 = best_data.groupby('Estimator').agg({
            'MSE': 'mean', 'Bias': 'mean', 'CP': 'mean', 
            'ACIL': 'mean', 'PI': 'mean', 'RE': 'mean'
        }).round(4)
        print(table1)
        table1.to_csv('Table1_Best_Case.csv')
    
    print("\n" + "=" * 70)
    print("TABLE 2: Worst Case (|δ| = max)")
    print("=" * 70)
    
    worst_data = df[df['delta_abs'] == df['delta_abs'].max()]
    if len(worst_data) > 0:
        table2 = worst_data.groupby('Estimator').agg({
            'MSE': 'mean', 'Bias': 'mean', 'CP': 'mean', 
            'ACIL': 'mean', 'PI': 'mean', 'RE': 'mean'
        }).round(4)
        print(table2)
        table2.to_csv('Table2_Worst_Case.csv')
    
    print("\n" + "=" * 70)
    print("TABLE 3: ICP (Integrated Coverage Probability)")
    print("=" * 70)
    
    icp_table = df.groupby(['R_true', 'Estimator']).agg({'ICP': 'first'}).round(4)
    icp_pivot = icp_table.unstack()
    print(icp_pivot)
    icp_pivot.to_csv('Table3_ICP.csv')


