def calculate_R_k_n(theta1, theta2, k, n_sys):
  """
    Calculate reliability of k-out-of-n system
    R_{k:n} = P(Y < X_{(k)}) where X ~ Exp(theta1), Y ~ Exp(theta2)
    """
R = 0
ratio = theta2 / theta1
for j in range(k, n_sys + 1):
  comb_val = comb(n_sys, j)
beta_val = beta(j + ratio, n_sys - j + 1)
R += comb_val * ratio * beta_val
return min(max(R, 0), 1)


def compute_R_mle_and_se_weibull(data_x, data_y, k, n_sys, n_boot_se=200):
  """Compute R_mle and its standard error using bootstrap"""
theta1_hat, c1_hat = fit_weibull_mle(data_x)
theta2_hat, c2_hat = fit_weibull_mle(data_y)
R_mle = calculate_R_k_n(theta1_hat, theta2_hat, k, n_sys)

n1, n2 = len(data_x), len(data_y)
boot_R = []
for _ in range(n_boot_se):
  boot_x = np.random.choice(data_x, n1, replace=True)
boot_y = np.random.choice(data_y, n2, replace=True)
theta1_b, _ = fit_weibull_mle(boot_x)
theta2_b, _ = fit_weibull_mle(boot_y)
boot_R.append(calculate_R_k_n(theta1_b, theta2_b, k, n_sys))

se_R_mle = np.std(boot_R)
var_R_mle = se_R_mle**2

return R_mle, se_R_mle, var_R_mle, theta1_hat, theta2_hat, c1_hat, c2_hat


def compute_optimal_shrinkage_coefficient(var_R_mle, delta_sq):
  """d* = σ² / (σ² + δ²)"""
return var_R_mle / (var_R_mle + delta_sq + 1e-10)


def shrinkage_estimators_fixed(data_x, data_y, R0, k, n_sys, alpha=0.7,
                               R_mle=None, se_R_mle=None, var_R_mle=None):
  """Compute all shrinkage estimators"""
if R_mle is None or se_R_mle is None:
  R_mle, se_R_mle, var_R_mle, _, _, _, _ = compute_R_mle_and_se_weibull(data_x, data_y, k, n_sys)

var_R = var_R_mle
delta = R_mle - R0
delta_sq = delta**2
ell_R = delta_sq / (var_R + 1e-10)
d_optimal = compute_optimal_shrinkage_coefficient(var_R, delta_sq)

# Stein-Type Estimator (Weighted Average Form - STABLE)
denom = ell_R + d_optimal + 1e-10
weight_mle = ell_R / denom
weight_R0 = d_optimal / denom
R_stein = weight_mle * R_mle + weight_R0 * R0

# Positive-Part Stein
if ell_R > 1e-10:
  shrinkage_factor = max(0, 1 - d_optimal / ell_R)
R_stein_positive = R0 + shrinkage_factor * (R_mle - R0)
else:
  R_stein_positive = R0

# Preliminary Test Estimator
chi2_critical = stats.chi2.ppf(0.95, df=1)
w = alpha
if ell_R <= chi2_critical:
  R_pte = R_mle - w * (R_mle - R0)
else:
  R_pte = R_mle

# Constant Weight
R_cw = alpha * R_mle + (1 - alpha) * R0

# Thompson
R_th = R_mle - (R_mle - R0) / (1 + ell_R)

# Mehta-Srinivasan
R_ms = R_th if ell_R < chi2_critical else R_mle

return {
  'R_mle': R_mle,
  'R_cw': R_cw,
  'R_th': R_th,
  'R_ms': R_ms,
  'R_stein': R_stein,
  'R_stein_positive': R_stein_positive,
  'R_pte': R_pte,
  'var_R_mle': var_R_mle,
  'se_R_mle': se_R_mle,
  'ell_R': ell_R,
  'd_optimal': d_optimal,
  'weight_mle': weight_mle
}


