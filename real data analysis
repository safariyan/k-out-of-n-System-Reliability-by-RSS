def gef_pdf(x, theta, c=1):
  """GEF PDF: f(x) = θ c x^(c-1) exp(-θ x^c)"""
return theta * c * (x ** (c-1)) * np.exp(-theta * (x ** c))


def gef_cdf(x, theta, c=1):
  """GEF CDF: F(x) = 1 - exp(-θ x^c)"""
return 1 - np.exp(-theta * (x ** c))


def gef_quantile(p, theta, c=1):
  """GEF Quantile: Q(p) = (-log(1-p)/θ)^(1/c)"""
return ((-np.log(1-p)) / theta) ** (1/c)


# =======================================================
# 3. Distribution Fitting Functions
# =======================================================

def fit_exponential(data):
  """Fit Exponential: c=1, θ=1/mean"""
theta_hat = 1 / np.mean(data)
return theta_hat, 1.0


def fit_weibull(data):
  """Fit Weibull using MLE"""
def neg_log_likelihood(params):
  c, theta = params
if c <= 0 or theta <= 0:
  return 1e10
n = len(data)
log_lik = n * np.log(theta * c) + (c-1) * np.sum(np.log(data + 1e-10)) - theta * np.sum((data + 1e-10) ** c)
return -log_lik

cv = np.std(data) / np.mean(data)
c_init = 1.2 if cv > 0.5 else 2.0
theta_init = (np.mean((data + 1e-10) ** c_init)) ** (-1/c_init)

result = minimize(neg_log_likelihood, [c_init, theta_init], 
                  bounds=[(0.1, 10), (0.01, 100)])
if result.success:
  return result.x[1], result.x[0]
return theta_init, c_init


def fit_gamma(data):
  """Fit Gamma distribution"""
data_pos = data + 1e-10
shape, loc, scale = stats.gamma.fit(data_pos, floc=0)
return shape, scale


def fit_lognormal(data):
  """Fit Log-normal distribution"""
data_pos = data + 1e-10
shape, loc, scale = stats.lognorm.fit(data_pos, floc=0)
return shape, scale


def fit_inverse_gaussian(data):
  """Fit Inverse Gaussian distribution"""
data_pos = data + 1e-10
mu = np.mean(data_pos)
lam = 1 / np.mean(1/data_pos - 1/mu)
return mu, lam


