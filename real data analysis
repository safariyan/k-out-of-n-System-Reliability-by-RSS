# 3. Bootstrap Confidence Intervals
# =======================================================

def bootstrap_ci_real_data(data_x, data_y, R0, k, n_sys, alpha=0.7, n_boot=500):
  """Bootstrap confidence intervals for all estimators"""
n_x, n_y = len(data_x), len(data_y)

# Original estimates
R_mle, se_R_mle, var_R_mle, theta1, theta2, c1, c2 = compute_R_mle_and_se_weibull(data_x, data_y, k, n_sys)
est_orig = shrinkage_estimators_fixed(data_x, data_y, R0, k, n_sys, alpha, R_mle, se_R_mle, var_R_mle)

estimator_names = ['MLE', 'CW', 'Thompson', 'MS', 'Stein', 'PS', 'PTE']
boot_results = {name: [] for name in estimator_names}

print(f"    Bootstrap: {n_boot} iterations...")

for b in range(n_boot):
  boot_x = np.random.choice(data_x, n_x, replace=True)
boot_y = np.random.choice(data_y, n_y, replace=True)

R_mle_b, se_R_mle_b, var_R_mle_b, _, _, _, _ = compute_R_mle_and_se_weibull(boot_x, boot_y, k, n_sys)

boot_est = shrinkage_estimators_fixed(
  boot_x, boot_y, R0, k, n_sys, alpha,
  R_mle=R_mle_b, se_R_mle=se_R_mle_b, var_R_mle=var_R_mle_b
)

boot_results['MLE'].append(boot_est['R_mle'])
boot_results['CW'].append(boot_est['R_cw'])
boot_results['Thompson'].append(boot_est['R_th'])
boot_results['MS'].append(boot_est['R_ms'])
boot_results['Stein'].append(boot_est['R_stein'])
boot_results['PS'].append(boot_est['R_stein_positive'])
boot_results['PTE'].append(boot_est['R_pte'])

ci_results = {}
for name in estimator_names:
  values = np.array(boot_results[name])
ci_results[name] = {
  'mean': np.mean(values),
  'std': np.std(values),
  'lower': np.percentile(values, 2.5),
  'upper': np.percentile(values, 97.5),
  'lower_90': np.percentile(values, 5),
  'upper_90': np.percentile(values, 95)
}

estimates = {
  'MLE': est_orig['R_mle'],
  'CW': est_orig['R_cw'],
  'Thompson': est_orig['R_th'],
  'MS': est_orig['R_ms'],
  'Stein': est_orig['R_stein'],
  'PS': est_orig['R_stein_positive'],
  'PTE': est_orig['R_pte']
}

return estimates, ci_results, est_orig, (theta1, theta2, c1, c2)


