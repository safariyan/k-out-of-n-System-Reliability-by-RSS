def perform_gof_tests(data, dist_name, params):
  """Perform comprehensive goodness-of-fit tests"""
results = {}
n = len(data)
data_pos = data + 1e-10

# Kolmogorov-Smirnov test
if dist_name == 'Exponential':
  theta, c = params
ks_stat, ks_p = kstest(data_pos, 'expon', args=(0, 1/theta))
elif dist_name == 'Weibull':
  theta, c = params
transformed = (data_pos ** c) * theta
ks_stat, ks_p = kstest(transformed, 'expon')
elif dist_name == 'Gamma':
  shape, scale = params
ks_stat, ks_p = kstest(data_pos, 'gamma', args=(shape, 0, scale))
elif dist_name == 'Lognormal':
  shape, scale = params
ks_stat, ks_p = kstest(data_pos, 'lognorm', args=(shape, 0, scale))
elif dist_name == 'Inverse Gaussian':
  mu, lam = params
transformed = np.sqrt(lam/data_pos) * (data_pos/mu - 1)
ks_stat, ks_p = kstest(transformed, 'norm')
else:
  ks_stat, ks_p = np.nan, np.nan

results['KS_stat'] = ks_stat
results['KS_p'] = ks_p

# Log-likelihood, AIC, BIC
if dist_name == 'Exponential':
  theta, c = params
log_lik = n * np.log(theta) - theta * np.sum(data_pos)
k_param = 1
elif dist_name == 'Weibull':
  theta, c = params
log_lik = n * np.log(theta * c) + (c-1) * np.sum(np.log(data_pos)) - theta * np.sum(data_pos ** c)
k_param = 2
elif dist_name == 'Gamma':
  shape, scale = params
log_lik = np.sum(stats.gamma.logpdf(data_pos, shape, 0, scale))
k_param = 2
elif dist_name == 'Lognormal':
  shape, scale = params
log_lik = np.sum(stats.lognorm.logpdf(data_pos, shape, 0, scale))
k_param = 2
elif dist_name == 'Inverse Gaussian':
  mu, lam = params
log_lik = np.sum(stats.invgauss.logpdf(data_pos, mu/lam, scale=lam))
k_param = 2
else:
  log_lik = 0
k_param = 2

results['log_lik'] = log_lik
results['AIC'] = -2 * log_lik + 2 * k_param
results['BIC'] = -2 * log_lik + k_param * np.log(n)

return results


